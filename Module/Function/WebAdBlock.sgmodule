[Map Local]
# > 10 PornHub[网页优化]@ddgksf2013 - 网站地址：https://cn.pornhub.com
^https:\/\/(cn|www)\.pornhub\.com\/_xa\/ads data="https://raw.githubusercontent.com/mieqq/mieqq/master/reject-dict.json"

[Script]
# > 16 泥巴影视[网页优化]@Adblock4limbo - 网站地址：https://m.nivod4.tv
nivod_17 = type=http-response, pattern=^https?:\/\/.*nivod.*\/($|[0-9a-zA-Z=_/-]+\.html), script-path=https://github.com/ddgksf2013/Scripts/raw/master/nivod.js, requires-body=true, timeout=60

# > 15 FreeOk[网页优化]@ddgksf2013 - 网站地址：https://www.freeok.vip
freeok_19 = type=http-response, pattern=^https?:\/\/www\.freeok\.vip(\/$|\/[0-9a-zA-Z=_/-]+\.html$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/freeok.js, requires-body=true, timeout=60

# > 14 奈飞鸭[网页优化]@ddgksf2013 - 网站地址：https://yanetflix.com [未测试]
netflix_21 = type=http-response, pattern=^https?:\/\/.*netflix.*\/($|[0-9a-zA-Z=_/-]+\.html$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/netflix.js, requires-body=true, timeout=60

# > 13 哔嘀影视[网页优化]@ddgksf2013 - 网站地址：https://www.bdys01.com 
bdys_23 = type=http-response, pattern=^https?:\/\/.*bdys.*com\/($|([a-z]+)\/(play\/)?\d+.*$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/bdys.js, requires-body=true, timeout=60

# > 12 茶杯狐[网页优化]@ddgksf2013 - 网站地址：https://cupfox.app
cupbox_25 = type=http-response, pattern=^https?:/\/.*cupfox\.app\/($|[\u4E00-\u9FFFa-zA-Z0-9%=_/-]+$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/cupbox.js, requires-body=true, timeout=60

# > 11 Cokemv[网页优化]@ddgksf2013 - 网站地址：https://cokemv.me 
cokemv_27 = type=http-response, pattern=^https?:/\/cokemv\.me\/($|vod.*$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/cokemv.js, requires-body=true, timeout=60

pornhub_30 = type=http-response, pattern=^https?:/\/(cn|www)\.pornhub\.com\/($|(view|video).*$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/pornhub.js, requires-body=true, timeout=60

# > 09 LeZhu[网页优化]@ddgksf2013 - 网站地址：http://www.lezhutv.com
lezhu_32 = type=http-response, pattern=^https?:/\/.*lezhutv\.com\/($|(type|detail|play|index).*$), script-path=https://github.com/ddgksf2013/Scripts/raw/master/lezhu.js, requires-body=true, timeout=60

